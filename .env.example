# Database (Prisma) – Project Settings → Database → Connection string
# If migrations timeout with "advisory lock" on Supabase, use "Direct connection" (port 6543) here.
DATABASE_URL="postgresql://user:password@host:5432/database"

# Supabase (optional – for client features; publishable key is safe in frontend)
# Project URL: https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_or_publishable_key"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# Email – SMTP (Titan, Gmail, Outlook, etc.)
# Titan: smtp.titan.email, port 587
SMTP_HOST="smtp.titan.email"
SMTP_PORT="587"
SMTP_USER="hello@spinkit.shop"
SMTP_PASS="your-titan-password"
SMTP_FROM_EMAIL="Spinkit <hello@spinkit.shop>"

# Contact form: where to send notification emails (default: hello@spinkitshop.com)
CONTACT_EMAIL="hello@spinkitshop.com"

# Optional: canonical site URL for emails and OG tags (e.g. https://spinkit-shop.com)
NEXT_PUBLIC_SITE_URL="https://spinkit-shop.com"
